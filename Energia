import pandas as pd

def procurar_colunas_depara(df, coluna_base):
    resultados = []

    for coluna in df.columns:
        if coluna == coluna_base:
            continue

        base = df[[coluna_base, coluna]].copy()

        base[coluna_base] = base[coluna_base].astype(str).str.strip()
        base[coluna] = base[coluna].astype(str).str.strip()

        base = base[
            (base[coluna_base].notna()) &
            (base[coluna].notna()) &
            (base[coluna_base] != "nan") &
            (base[coluna] != "nan") &
            (base[coluna_base] != "") &
            (base[coluna] != "")
        ]

        if base.empty:
            continue

        resumo = (
            base
            .groupby(coluna_base)
            .agg(
                qtd_linhas=(coluna, "size"),
                qtd_valores_diferentes=(coluna, "nunique")
            )
            .reset_index()
        )

        qtd_codigos = len(resumo)
        qtd_codigos_unicos = (resumo["qtd_valores_diferentes"] == 1).sum()
        qtd_codigos_conflito = (resumo["qtd_valores_diferentes"] > 1).sum()

        total_linhas = resumo["qtd_linhas"].sum()
        linhas_validas = resumo.loc[
            resumo["qtd_valores_diferentes"] == 1,
            "qtd_linhas"
        ].sum()

        acuracia_codigos = qtd_codigos_unicos / qtd_codigos * 100 if qtd_codigos > 0 else 0
        acuracia_linhas = linhas_validas / total_linhas * 100 if total_linhas > 0 else 0

        resultados.append({
            "coluna_candidata": coluna,
            "qtd_codigos": qtd_codigos,
            "codigos_com_depara_unico": qtd_codigos_unicos,
            "codigos_com_conflito": qtd_codigos_conflito,
            "acuracia_por_codigos_%": round(acuracia_codigos, 2),
            "acuracia_por_linhas_%": round(acuracia_linhas, 2)
        })

    return (
        pd.DataFrame(resultados)
        .sort_values(
            by=["acuracia_por_codigos_%", "acuracia_por_linhas_%"],
            ascending=False
        )
    )

resultado = procurar_colunas_depara(
    df,
    coluna_base="sequencia_pessoa_fornecedora"
)

