df_datasets = buscar_datasets()

df_monitorados = df_datasets[df_datasets["monitorar"]].copy()
df_excluidos = df_datasets[~df_datasets["monitorar"]].copy()

print(f"Total de modelos encontrados: {len(df_datasets)}")
print(f"Total de modelos monitorados: {len(df_monitorados)}")
print(f"Total de modelos excluídos: {len(df_excluidos)}")

display(df_monitorados[["Dataset Name", "Dataset ID"]])
display(df_excluidos[["Dataset Name", "Dataset ID"]])

linhas_controle = []
linhas_historico = []
linhas_agendamento = []

qtd_modelos_retry = 0

for idx, row in df_monitorados.iterrows():
    modelo = row["Dataset Name"]
    dataset_id = row["Dataset ID"]

    print("\n" + "=" * 80)
    print(f"Processando modelo: {modelo}")
    print(f"Dataset ID: {dataset_id}")

    # --------------------------------------------------------
    # 1. Buscar histórico
    # --------------------------------------------------------
    df_refresh_raw, erro_historico = buscar_historico_refresh(modelo)

    if erro_historico:
        print(f"Erro ao buscar histórico de {modelo}: {erro_historico}")
        df_hist_modelo = pd.DataFrame()
    else:
        df_hist_modelo = tratar_historico_refresh(df_refresh_raw, modelo, dataset_id)
        print(f"Histórico encontrado: {len(df_hist_modelo)} linhas")

    # --------------------------------------------------------
    # 2. Buscar agendamento
    # --------------------------------------------------------
    schedule, erro_schedule = buscar_agendamento(modelo, dataset_id)

    if erro_schedule:
        print(f"Erro ao buscar agendamento de {modelo}: {erro_schedule}")
    else:
        print("Agendamento encontrado.")

    df_ag_modelo = tratar_agendamento(schedule, modelo, dataset_id)
    linhas_agendamento.append(df_ag_modelo)

    # --------------------------------------------------------
    # 3. Verificar se precisa retry por timeout
    # --------------------------------------------------------
    tentou_retry = False
    retry_request_id = None
    retry_status = None

    if executar_retry_timeout and not df_hist_modelo.empty:
        df_ordenado = df_hist_modelo.sort_values(
            by=["inicio_refresh_brt", "fim_refresh_brt"],
            ascending=False,
            na_position="last"
        )

        ultimo_refresh = df_ordenado.iloc[0]
        ultimo_status = str(ultimo_refresh.get("Status")).lower()
        ultimo_tipo_erro = ultimo_refresh.get("tipo_erro")

        if (
            ultimo_status == "failed"
            and ultimo_tipo_erro == "Erro de Time Out"
            and qtd_modelos_retry < max_modelos_com_retry_por_execucao
        ):
            print(f"Timeout detectado no último refresh de {modelo}.")
            print(f"Aguardando {espera_retry_minutos} minutos antes do retry full...")

            time.sleep(espera_retry_minutos * 60)

            try:
                retry_request_id = disparar_retry_full(modelo)
                tentou_retry = True
                qtd_modelos_retry += 1

                print(f"Retry full disparado para {modelo}.")
                print(f"Retry Request ID: {retry_request_id}")

                retry_status = monitorar_request(modelo, retry_request_id)

                print(f"Retry finalizado com status: {retry_status}")

                # Rebuscar histórico depois do retry
                df_refresh_raw_pos_retry, erro_hist_pos_retry = buscar_historico_refresh(modelo)

                if not erro_hist_pos_retry:
                    df_hist_modelo = tratar_historico_refresh(
                        df_refresh_raw_pos_retry,
                        modelo,
                        dataset_id
                    )

            except Exception as e:
                tentou_retry = True
                retry_status = f"Erro ao disparar retry: {e}"
                print(retry_status)

        elif (
            ultimo_status == "failed"
            and ultimo_tipo_erro == "Erro de Time Out"
            and qtd_modelos_retry >= max_modelos_com_retry_por_execucao
        ):
            print("Timeout detectado, mas limite de modelos com retry nesta execução foi atingido.")

    # --------------------------------------------------------
    # 4. Guardar histórico tratado
    # --------------------------------------------------------
    if not df_hist_modelo.empty:
        df_hist_modelo["tentou_retry_timeout_na_coleta"] = tentou_retry
        df_hist_modelo["retry_request_id_na_coleta"] = retry_request_id
        df_hist_modelo["retry_status_na_coleta"] = retry_status
        linhas_historico.append(df_hist_modelo)

    # --------------------------------------------------------
    # 5. Montar controle atual
    # --------------------------------------------------------
    controle = criar_controle_atual(
        modelo=modelo,
        dataset_id=dataset_id,
        df_hist_modelo=df_hist_modelo,
        schedule=schedule,
        erro_historico=erro_historico,
        erro_schedule=erro_schedule,
        tentou_retry=tentou_retry,
        retry_request_id=retry_request_id,
        retry_status=retry_status
    )

    linhas_controle.append(controle)


# ============================================================
# MONTAR DATAFRAMES FINAIS
# ============================================================

df_controle_atual = pd.DataFrame(linhas_controle)

if linhas_historico:
    df_historico = pd.concat(linhas_historico, ignore_index=True)
else:
    df_historico = pd.DataFrame()

if linhas_agendamento:
    df_agendamento = pd.concat(linhas_agendamento, ignore_index=True)
else:
    df_agendamento = pd.DataFrame()


# ============================================================
# ORGANIZAR COLUNAS PRINCIPAIS
# ============================================================

print("\n" + "=" * 80)
print("Controle atual:")
display(df_controle_atual)

print("Histórico:")
display(df_historico)

print("Agendamento:")
display(df_agendamento)


# ============================================================
# GRAVAR NO LAKEHOUSE
# ============================================================

salvar_overwrite(df_controle_atual, tabela_controle_atual)
salvar_historico_sem_duplicar(df_historico, tabela_historico)
salvar_overwrite(df_agendamento, tabela_agendamento)

print("\nProcesso concluído.")
print("Tabelas geradas:")
print(f"- {tabela_controle_atual}")
print(f"- {tabela_historico}")
print(f"- {tabela_agendamento}")
